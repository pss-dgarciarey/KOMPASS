# Backend runtime
# The defaults below are meant to boot locally without drama.
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
SQLITE_PATH=./data/kompass.sqlite

# GDELT ingestion
# If coverage gets noisy, tune the slice sizes before widening the query again.
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_QUERY=toneabs>1
GDELT_COUNTRY_SLICES=
GDELT_TIMESPAN=1h
GDELT_MAX_RECORDS=150
GDELT_MIN_REQUEST_GAP=5500
GDELT_KEEP_LAST_LIVE=2h
GDELT_EXPORT_LOOKBACK_BATCHES=8
GDELT_COUNTRY_OUTLET_BATCH_SIZE=12
GDELT_CONFLICT_OUTLET_BATCH_SIZE=10
GDELT_COUNTRY_PULSE_BATCH_SIZE=8
GDELT_SHIPPING_FEED_BATCH_SIZE=6
GDELT_SOCIAL_FEED_BATCH_SIZE=4
ENABLE_CONFLICT_OUTLET_FEEDS=true
ENABLE_COUNTRY_PULSE_FEEDS=true
ENABLE_SHIPPING_FEEDS=true
ENABLE_SOCIAL_FEEDS=true

# Free market data
# Yahoo is the default because it is free, not because it is always polite.
FINANCE_PROVIDER=yahoo
ALTERNATIVE_ME_KEY=
FINANCE_MIN_REQUEST_GAP=5s

# Polling and caching
# Free providers tend to punish impatience.
POLL_INTERVAL_GDELT=5m
POLL_INTERVAL_FINANCE=5s
ALERT_EVALUATION_INTERVAL=1m
CACHE_TTL=5m
TOP_EVENT_LIMIT=5
TOP_COUNTRIES_LIMIT=200
METRICS_LOOKBACK=24h
MARKET_MOOD_BASELINE_DAYS=90
KGPI_BASELINE_POINTS=2000

# Security and alerts
ALERT_WEBHOOK_SECRET=

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api
